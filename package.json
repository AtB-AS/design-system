{
  "name": "@atb-as/design-system-monorepo",
  "version": "1.0.0",
  "description": "Collection of packages for managing colors, themes and shared design",
  "main": "index.js",
  "license": "EUPL-1.2",
  "private": true,
  "keywords": [
    "design system",
    "atb"
  ],
  "devDependencies": {
    "typescript": "^5.1.6"
  },
  "dependencies": {},
  "scripts": {
    "build": "pnpm --filter @atb-as/theme build && pnpm --filter @atb-as/generate-assets build",
    "clean": "pnpm --filter @atb-as/theme clean && pnpm --filter @atb-as/generate-assets clean",
    "fetch-variables": "pnpm --filter @atb-as/theme fetch-variables"
  },
  "packageManager": "pnpm@11.1.1"
}
